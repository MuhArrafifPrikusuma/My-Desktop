// ### DEFAULT Laptop  - Top ### //
{
  "include": [
    "$HOME/.config/waybar/Modules",
    "$HOME/.config/waybar/ModulesWorkspaces",
    "$HOME/.config/waybar/ModulesCustom",
    "$HOME/.config/waybar/ModulesGroups",
    "$HOME/.config/waybar/UserModules"
  ],
  "layer": "top",
  "exclusive": true,
  "passthrough": false,
  "position": "top",
  "spacing": 3,
  "fixed-center": true,
  "ipc": true,
  "margin-top": 3,
  "margin-left": 8,
  "margin-right": 8,

  "modules-left": [
    "custom/separator#blank",
    "custom/cava_mviz",
    "custom/separator#blank",
    "custom/playerctl",
    "custom/separator#blank",
    "hyprland/window",
    "custom/mysql"  // !
  ],

  "modules-center": [
    "custom/separator#blank",
    "group/app_drawer",
    "group/notify",
    "hyprland/workspaces#rw",
    "clock",
    "idle_inhibitor",	
    "custom/hint"	
  ],

  "modules-right": [
    "tray",
    "network#speed",
    "group/laptop",
    "group/mobo_drawer",
    "group/audio",
    "custom/nightlight",
    "group/status"
  ],

  // The actual module settings belong down here outside the layout arrays
  "custom/mysql": {
    "format": "{}",
    "return-type": "json",
    "exec": "$HOME/.config/waybar/scripts/mysql-status.sh", 
    "interval": 2, 
    
    // Combine multiple commands into a single valid string using && or ;
    "on-click": "pkexec systemctl enable --now mysqld && pkexec systemctl enable --now httpd",
    "on-click-right": "pkexec systemctl disable --now mysqld && pkexec systemctl disable --now httpd",
    
    "tooltip": true
  }
}
